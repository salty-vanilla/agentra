# Copy this file to .env.local and fill in values.
# .env.local is git-ignored — never commit secrets or PATs.

AGENTRA_AWS_PROFILE=quick-admin
AGENTRA_STAGE=dev

THIRD_PARTY_API_KEY_SECRET_ARN=
AMPLIFY_GITHUB_REPOSITORY=https://github.com/salty-vanilla/agentra
AMPLIFY_GITHUB_BRANCH=main
AMPLIFY_URL=

# Required for cdk-deploy-all only — keep local, never commit
AMPLIFY_GITHUB_PAT=

# Required for smoke-agentcore and smoke-slide
AGENTCORE_RUNTIME_ARN=
