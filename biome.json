{
  "files": {
    "includes": [
      "**",
      "!**/.next",
      "!**/dist",
      "!**/cdk.out",
      "!**/node_modules",
      "!apps/frontend/public/mockServiceWorker.js",
      "!apps/frontend/lib/generated",
      "!apps/frontend/mocks/generated",
      "!apps/frontend/out",
      "!apps/frontend/out",
      "!packages/shared/src/generated"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 90
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  }
}
