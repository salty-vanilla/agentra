{
  "files": {
    "includes": [
      "**",
      "!**/.tmp",
      "!**/.next",
      "!**/dist",
      "!**/cdk.out",
      "!**/node_modules",
      "!**/vendor",
      "!apps/frontend/public/mockServiceWorker.js",
      "!apps/frontend/lib/generated",
      "!apps/frontend/mocks/generated",
      "!apps/frontend/out",
      "!apps/frontend/out",
      "!packages/shared/src/generated"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 90
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "patterns": [
              {
                "group": ["**/apps/**", "**/packages/**", "**/infra/**"],
                "message": "Use a workspace package dependency instead of a cross-package relative import."
              }
            ]
          }
        }
      }
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  }
}
