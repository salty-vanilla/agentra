{
  "name": "@agentra/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/dev.ts",
    "start": "node --import tsx src/dev.ts",
    "build": "pnpm --filter @agentra/shared build && tsc -p tsconfig.build.json",
    "chat:direct": "node --import tsx src/tools/direct-chat.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run && pnpm contract",
    "contract": "pnpm --filter @agentra/shared build && node --import tsx src/contract.ts"
  },
  "dependencies": {
    "@agentra/shared": "workspace:*",
    "@aws-sdk/client-bedrock-agentcore": "^3.1032.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1032.0",
    "@aws-sdk/client-dynamodb": "latest",
    "@aws-sdk/lib-dynamodb": "latest",
    "@hono/node-server": "latest",
    "ajv-formats": "^3.0.1",
    "hono": "latest",
    "jose": "^6.2.2",
    "openapi-backend": "^5.16.1",
    "zod": "4.4.3",
    "uuidv7": "^1.2.1"
  },
  "devDependencies": {
    "@types/aws-lambda": "latest",
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
