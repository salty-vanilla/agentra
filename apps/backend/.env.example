HOST=127.0.0.1
PORT=8787

# Store type: "memory" (default, local dev) | "dynamo" (production AWS)
# Choose based on environment:
#   - Local development: STORE_TYPE=memory
#   - Production: STORE_TYPE=dynamo (requires DynamoDB tables and Cognito)
STORE_TYPE=memory

# DynamoDB table names (required only when STORE_TYPE=dynamo)
THREADS_TABLE_NAME=
MESSAGES_TABLE_NAME=
USERS_TABLE_NAME=

# Cognito (required only when STORE_TYPE=dynamo)
COGNITO_USER_POOL_ID=
COGNITO_REGION=ap-northeast-1
COGNITO_USER_POOL_CLIENT_ID=

# Auth bypass: LOCAL DEVELOPMENT ONLY
# Set to "true" ONLY when using STORE_TYPE=memory for local dev without Cognito.
# NEVER use SKIP_AUTH=true with STORE_TYPE=dynamo (will fail startup).
# When true: all requests are treated as user 'user-demo-001' without JWT verification.
SKIP_AUTH=true
