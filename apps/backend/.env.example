HOST=127.0.0.1
PORT=8787

# Store type: "memory" (default, local dev) | "dynamo" (AWS)
STORE_TYPE=memory

# DynamoDB table names (required when STORE_TYPE=dynamo)
THREADS_TABLE_NAME=
MESSAGES_TABLE_NAME=
USERS_TABLE_NAME=

# Cognito (required when STORE_TYPE=dynamo, ignored when SKIP_AUTH=true)
COGNITO_USER_POOL_ID=
COGNITO_REGION=ap-northeast-1

# Set to "true" to bypass JWT verification in local dev (userId = user-demo-001)
SKIP_AUTH=true
