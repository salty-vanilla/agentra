{
  "name": "@agentra/frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3000",
    "build": "next build",
    "start": "next start --hostname 127.0.0.1 --port 3000",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test --project=chromium",
    "e2e:mock": "NEXT_PUBLIC_API_MODE=mock playwright test --project=chromium",
    "test:e2e:mock:visual-evidence": "NEXT_PUBLIC_API_MODE=mock playwright test --project=visual-evidence",
    "e2e:mock:modal-performance": "NEXT_PUBLIC_API_MODE=mock playwright test --project=modal-performance",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test-storybook": "test-storybook",
    "playwright:install": "playwright install --with-deps chromium",
    "storybook:serve-static": "http-server storybook-static --port 6006 --silent",
    "test-storybook:ci": "test-storybook --url http://127.0.0.1:6006"
  },
  "dependencies": {
    "@agentra/shared": "workspace:*",
    "@assistant-ui/core": "^0.1.14",
    "@assistant-ui/react": "^0.12.25",
    "@assistant-ui/react-markdown": "^0.12.9",
    "@base-ui/react": "^1.5.0",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-table": "^8.21.0",
    "@tanstack/react-virtual": "^3.13.24",
    "aws-amplify": "^6.16.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "next": "^15.5.2",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "react": "latest",
    "react-dom": "latest",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.3.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "uuidv7": "^1.2.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@faker-js/faker": "^10.4.0",
    "@storybook/nextjs-vite": "^9.1.20",
    "@storybook/test-runner": "^0.23.0",
    "http-server": "^14.1.1",
    "playwright": "^1.60.0",
    "wait-on": "^9.0.10",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "jsdom": "^29.1.1",
    "msw": "^2.13.4",
    "msw-storybook-addon": "^2.0.7",
    "postcss": "^8.5.10",
    "storybook": "^9.1.20",
    "tailwindcss": "^4.2.2",
    "typescript": "latest",
    "vitest": "^4.1.7"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
