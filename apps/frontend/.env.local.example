# Backend HTTP API URL (CDK の HttpApiUrl Output をデプロイ後に設定)
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8787

# Streaming API URL for /chat SSE (CDK の StreamingApiUrl Output をデプロイ後に設定)
# falls back to NEXT_PUBLIC_API_BASE_URL when unset (local dev)
NEXT_PUBLIC_STREAMING_API_BASE_URL=http://127.0.0.1:8787

# "mock" (default in dev) | "real" (AWS 環境)
NEXT_PUBLIC_API_MODE=mock

# Cognito (NEXT_PUBLIC_API_MODE=real のときに必要 — CDK Outputs から取得)
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_CLIENT_ID=
NEXT_PUBLIC_COGNITO_DOMAIN=

# フロントエンドのデプロイ URL (Cognito コールバック URL に一致させる)
NEXT_PUBLIC_APP_URL=http://localhost:3000
