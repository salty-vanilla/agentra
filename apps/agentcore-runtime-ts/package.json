{
  "name": "@agentra/agentcore-runtime-ts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/agent.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/agent.js",
    "typecheck": "tsc --noEmit -p tsconfig.scripts.json",
    "profile:manufacturing-line": "tsx scripts/profile-manufacturing-line.ts",
    "smoke:chat": "tsx scripts/smoke-agentcore-chat.ts",
    "smoke:mfg": "tsx scripts/smoke-agentcore-manufacturing-line.ts",
    "smoke:slide": "tsx scripts/smoke-agentcore-slide.ts",
    "smoke:research": "tsx scripts/smoke-agentcore-web-research.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-agent-runtime": "^3.1038.0",
    "@aws-sdk/client-bedrock-agentcore": "^3.1038.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1032.0",
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/client-secrets-manager": "^3.1032.0",
    "@aws-sdk/client-ssm": "^3.1032.0",
    "@agentra/agent-tools": "workspace:*",
    "@serdnam/pino-cloudwatch-transport": "^1.0.4",
    "@strands-agents/sdk": "latest",
    "bedrock-agentcore": "latest",
    "uuidv7": "^1.2.1",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "fastify": "^5.8.5",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "^3.2.4"
  }
}
