{
  "name": "@agentra/presentation-author-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/agent.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/agent.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dogfood:presentation": "tsx scripts/dogfood-create-presentation.ts",
    "dogfood:fake": "tsx src/scripts/dogfood-fake-llm.ts",
    "docker:smoke": "node dist/scripts/docker-smoke.js"
  },
  "dependencies": {
    "@agentra/presentation-author": "workspace:*",
    "@aws-sdk/client-bedrock-runtime": "^3.1032.0",
    "@strands-agents/sdk": "latest",
    "pino": "^10.3.1",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "^3.2.4"
  }
}
