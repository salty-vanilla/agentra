{
  "name": "@agentra/presentation-author",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "PptxGenJS-based presentation authoring package",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "vendor",
    "templates"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "dogfood": "tsx scripts/dogfood.ts"
  },
  "dependencies": {
    "fontkit": "^2.0.2",
    "linebreak": "^1.1.0",
    "mathjax-full": "^3.2.2",
    "pptxgenjs": "^3.12.0",
    "prismjs": "^1.29.0",
    "skia-canvas": "^2.0.2"
  },
  "devDependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1038.0",
    "typescript": "latest"
  }
}
