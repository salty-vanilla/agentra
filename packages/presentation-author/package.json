{
  "name": "@agentra/presentation-author",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "PptxGenJS-based presentation authoring package",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "vendor",
    "templates",
    "assets"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "dogfood": "tsx scripts/dogfood.ts"
  },
  "dependencies": {
    "@agentra/shared": "workspace:*",
    "@aws-sdk/client-secrets-manager": "^3.1032.0",
    "@resvg/resvg-js": "^2.6.2",
    "fontkit": "^2.0.2",
    "jszip": "^3.10.1",
    "linebreak": "^1.1.0",
    "mathjax-full": "^3.2.2",
    "pptxgenjs": "^3.12.0",
    "prismjs": "^1.29.0",
    "skia-canvas": "^2.0.2",
    "uuidv7": "^1.2.1"
  },
  "devDependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1038.0",
    "typescript": "latest"
  }
}
