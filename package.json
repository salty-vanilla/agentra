{
  "name": "agentra",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.9.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "prepare": "if git rev-parse --git-dir > /dev/null 2>&1; then lefthook install; fi",
    "prepare:workspace": "pnpm generate:api && pnpm build:shared && pnpm --filter ./packages/presentation-author build && pnpm --filter ./packages/agent-tools build",
    "dev:frontend": "pnpm prepare:workspace && pnpm --filter @agentra/frontend dev",
    "dev:backend": "pnpm build:shared && pnpm --filter @agentra/backend dev",
    "dev:storybook": "pnpm --filter @agentra/frontend storybook",
    "generate:api": "node ./scripts/generate/run-generate-api.mjs",
    "validate:openapi": "node ./scripts/contract/validate-openapi.mjs",
    "contract:backend": "pnpm --filter @agentra/backend exec node --import tsx ./src/contract.ts",
    "build:shared": "pnpm --filter @agentra/shared build",
    "test": "pnpm prepare:workspace && pnpm -r --if-present test",
    "typecheck": "pnpm prepare:workspace && pnpm -r --if-present typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "synth": "pnpm --filter @agentra/infra-cdk synth",
    "seed:dynamo": "node scripts/seed/dynamo-seed.mjs",
    "smoke:agentcore:chat": "pnpm --filter @agentra/agentcore-runtime-ts smoke:chat",
    "smoke:agentcore:mfg": "pnpm --filter @agentra/agentcore-runtime-ts smoke:mfg",
    "smoke:agentcore:slide": "pnpm --filter @agentra/agentcore-runtime-ts smoke:slide",
    "smoke:agentcore:research": "pnpm --filter @agentra/agentcore-runtime-ts smoke:research",
    "smoke:bff": "pnpm --filter @agentra/backend smoke:bff",
    "smoke:bff:health": "pnpm --filter @agentra/backend smoke:bff:health",
    "smoke:bff:threads": "pnpm --filter @agentra/backend smoke:bff:threads",
    "smoke:bff:chat": "pnpm --filter @agentra/backend smoke:bff:chat",
    "smoke:frontend:mock": "pnpm --filter @agentra/frontend e2e:mock",
    "test:preview": "vitest run --config scripts/preview/vitest.config.ts",
    "test:frontend:visual-evidence": "pnpm --filter @agentra/frontend test:e2e:mock:visual-evidence",
    "typecheck:preview": "tsc -p scripts/preview/tsconfig.json --noEmit",
    "preview:plan": "tsx scripts/preview/plan.ts",
    "preview:deploy": "tsx scripts/preview/deploy.ts",
    "preview:outputs": "tsx scripts/preview/export-outputs.ts",
    "preview:destroy": "tsx scripts/preview/destroy.ts",
    "preview:cleanup": "tsx scripts/preview/cleanup.ts",
    "preview:smoke": "tsx scripts/preview/smoke.ts"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@aws-sdk/client-bedrock-agentcore": "^3.1038.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1038.0",
    "@biomejs/biome": "latest",
    "@types/node": "^24.10.1",
    "jszip": "^3.10.1",
    "lefthook": "latest",
    "orval": "^8.8.0",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "^3.2.4"
  }
}
