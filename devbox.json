{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.13.7/.schema/devbox.schema.json",
  "packages": [
    "nodejs@22",
    "pnpm@10.9.0",
    "just@1",
    "direnv@2",
    "awscli2@2",
    "uv@latest",
    "jq@1",
    "yq-go@4",
    "gh@2"
  ],
  "env": {
    "PATH": "$PWD/.devbox/bin:$PATH"
  },
  "shell": {
    "init_hook": ["mkdir -p .devbox/bin .devbox/tools"],
    "scripts": {
      "install": "pnpm install",
      "check": "pnpm lint && pnpm typecheck && pnpm test",
      "gtr:install": [
        "mkdir -p .devbox/bin .devbox/tools",
        "if [ ! -d .devbox/tools/git-worktree-runner ]; then git clone --depth 1 https://github.com/coderabbitai/git-worktree-runner.git .devbox/tools/git-worktree-runner; fi",
        "ln -sfn \"$PWD/.devbox/tools/git-worktree-runner/bin/git-gtr\" .devbox/bin/git-gtr",
        "chmod +x .devbox/tools/git-worktree-runner/bin/git-gtr",
        "git gtr version"
      ],
      "gtr:update": [
        "git -C .devbox/tools/git-worktree-runner pull --ff-only",
        "git gtr version"
      ],
      "gtr:doctor": "git gtr doctor"
    }
  }
}
