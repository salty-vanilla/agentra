[copy]
    include = .envrc
    include = .env.example
    include = .env
    include = .env.local
    include = .envrc.local
    include = .npmrc
    exclude = .env.worktree
    exclude = .artifacts
    exclude = .tmp

[hooks]
    postCreate = bash scripts/worktree/setup.sh
    postRemove = bash scripts/worktree/cleanup.sh "$GTR_WORKTREE_PATH"

[defaults]
    editor = code
    ai = claude
